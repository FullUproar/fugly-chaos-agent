{
  "expo": {
    "name": "Chaos Agent",
    "slug": "chaos-agent",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "icon": "./assets/icon.png",
    "scheme": "chaos-agent",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0A"
    },
    "notification": {
      "icon": "./assets/icon.png",
      "color": "#FF6B35",
      "androidMode": "default",
      "androidCollapsedTitle": "Chaos Agent"
    },
    "android": {
      "package": "com.fugly.chaosagent",
      "adaptiveIcon": {
        "backgroundColor": "#0A0A0A",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png"
      }
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      "expo-sharing"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9551d205-7f4f-4b36-b20c-2d982ca2662a"
      }
    },
    "owner": "fulluproar"
  }
}
